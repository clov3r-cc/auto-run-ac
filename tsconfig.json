{
  "files": [],
  "references": [
    { "path": "./tsconfig.node.json" },
    { "path": "./tsconfig.cloudflare.json" }
  ],
  "compilerOptions": {
    "checkJs": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "types": [
      "node",
      "./worker-configuration.d.ts",
      "@cloudflare/vitest-pool-workers"
    ],
    // shadcn/ui requires paths to be defined in the root tsconfig.json
    "paths": {
      "~/*": ["./app/*"],
      "lib/*": ["./lib/*"]
    }
  }
}
